PORT=3001
NODE_ENV=production

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://rdoone.com,https://www.rdoone.com

# Redis connection URL
REDIS_URL=redis://localhost:6379

# 1inch API key (get free key at portal.1inch.dev)
ONEINCH_API_KEY=your_key_here

# Aster Pro API (V3) — agent-based EIP-712 auth for signed endpoints
# (leverageBracket, account, positionRisk, orders, ...). Create the agent at
# asterdex.com -> API Wallet -> "Pro API" tab. NEVER commit the private key.
ASTER_SIGNER_ADDRESS=0xYourAgentAddress
ASTER_SIGNER_PRIVATE_KEY=your_agent_private_key_here

# Rate limiting
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000
